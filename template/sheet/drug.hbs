<div class="dark-heresy-item">
    <div class="header border">
        <div class="flex row">
            <div class="avatar">
                <img class="profile-img" src="{{item.img}}" alt="{{item.name}}" data-edit="img" data-action="editImage" title="{{item.name}}" />
            </div>
            <div class="flex column grow justify-center">
                <div class="name header-row">
                    <label>{{localize "DRUG.NAME"}}</label>
                    <input name="name" type="text" value="{{item.name}}" />
                </div>
            </div>
        </div>
    </div>

    <div class="sheet-tabs tabs flex row" data-group="primary">
        <b class="item" data-action="tab" data-group="primary" data-tab="data">{{localize "TAB.DATA"}}</b>
        <b class="item" data-action="tab" data-group="primary" data-tab="notes">{{localize "TAB.NOTES"}}</b>
        {{> systems/dark-heresy/template/sheet/item/parts/effect-tab-nav.hbs}}
    </div>

    <div class="sheet-body">
        <div class="tab" data-group="primary" data-tab="data">
            <div class="stats border">
                <h1>{{localize "TITLE.STATS"}}</h1>
                <div class="stats-row">
                    <div class="stat installed">
                        <label>{{localize "DRUG.IN_USE"}}</label>
                        <input name="system.installed" type="checkbox" data-dtype="Boolean" {{#if system.installed}}checked{{/if}}/>
                    </div>
                </div>
                <div class="stats-row">
                    <div class="stat craftsmanship">
                        <label>{{localize "DRUG.CRAFTSMANSHIP"}}</label>
                        <select name="system.craftsmanship">
                            {{selectOptions (config "craftmanship") selected=system.craftsmanship localize=true}}
                        </select>
                    </div>
                    <div class="stat availability">
                        <label>{{localize "DRUG.AVAILABILITY"}}</label>
                        <select name="system.availability">
                            {{selectOptions (config "availability") selected=system.availability localize=true}}
                        </select>
                    </div>
                    <div class="stat weight">
                        <label>{{localize "DRUG.WEIGHT"}}</label>
                        <input name="system.weight" type="number" value="{{system.weight}}" data-dtype="Number" />
                    </div>
                </div>
                <div class="stats-row">
                    <div class="stat short-description">
                        <label>{{localize "DRUG.SHORT_DESCRIPTION"}}</label>
                        <input name="system.shortDescription" type="text" value="{{system.shortDescription}}" />
                    </div>
                </div>
            </div>
        </div>
        <div class="tab" data-group="primary" data-tab="notes">
            <div class="notes-editor border">
                <h1>{{localize "TITLE.NOTES"}}</h1>
                <div class="notes-editor-body">
                    <prose-mirror name="system.description" toggled value="{{system.description}}" {{#unless editable}}disabled{{/unless}}>{{{enrichment.system.description}}}</prose-mirror>
                </div>
            </div>
        </div>
        {{> systems/dark-heresy/template/sheet/item/parts/effect-tab.hbs}}
    </div>
</div>