<div class="dark-heresy-item">
    <div class="header border">
        <div class="flex row">
            <div class="avatar">
                <img class="profile-img" src="{{item.img}}" alt="{{item.name}}" data-edit="img" data-action="editImage" title="{{item.name}}" />
            </div>
            <div class="flex column grow justify-center">
                <div class="name header-row">
                    <label>{{localize "CRITICAL_INJURY.NAME"}}</label>
                    <input name="name" type="text" value="{{item.name}}" />
                </div>
                <div class="header-row">
                    <div class="flex row part">
                        <label>{{localize "CRITICAL_INJURY.PART"}}</label>
                        <select name="system.part">
                             {{selectOptions (config "hitLocations") selected=system.part localize=true}}
                        </select>
                    </div>
                    <div class="flex row type">
                        <label>{{localize "CRITICAL_INJURY.TYPE"}}</label>
                        <select name="system.type">
                            {{selectOptions (config "damageTypes") selected=system.type localize=true}}
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="sheet-tabs tabs flex row" data-group="primary">
        <b class="item" data-action="tab" data-group="primary" data-tab="notes">{{localize "TAB.NOTES"}}</b>
        {{> systems/dark-heresy/template/sheet/item/parts/effect-tab-nav.hbs}}
    </div>

    <div class="sheet-body">
        <div class="tab" data-group="primary" data-tab="notes">
            <div class="notes-editor border">
                <h1>{{localize "TITLE.NOTES"}}</h1>
                <div class="notes-editor-body">
                    <prose-mirror name="system.description" toggled value="{{system.description}}" {{#unless editable}}disabled{{/unless}}>{{{enrichment.system.description}}}</prose-mirror>
                </div>
            </div>
        </div>
        {{> systems/dark-heresy/template/sheet/item/parts/effect-tab.hbs}}
    </div>
</div>