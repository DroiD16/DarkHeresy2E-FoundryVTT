    <div class="npc">
        <div class="header border">
            <div class="flex row">
                {{> systems/dark-heresy/template/sheet/actor/parts/avatar.hbs}}
                <div class="flex column grow">
                    <div class="name header-row">
                        <label>{{localize "BIO.NAME"}}</label>
                        <input name="name" type="text" value="{{actor.name}}" />
                    </div>
                    <div class="header-row">
                        <div class="type">
                            <label>{{localize "BIO.TYPE"}}</label>
                            <select name="system.type">
                                {{selectOptions (config "npcTypes") selected=system.type localize=true}}
                            </select>
                        </div>
                        <div class="threat-level">
                            <label>{{localize "BIO.THREAT_LEVEL"}}</label>
                            <input name="system.threatLevel" type="number" value="{{source.threatLevel}}" data-dtype="Number" />
                        </div>
                        <div class="fate">
                            <label>{{localize "FATE"}}</label>
                            <input name="system.fate.value" type="number" value="{{source.fate.value}}" data-dtype="Number" />
                            /
                            <input name="system.fate.max" type="number" value="{{source.fate.max}}" data-dtype="Number" />
                        </div>
                    </div>
                    <div class="header-row">
                        <div class="faction">
                            <label>{{localize "BIO.FACTION"}}</label>
                            <input name="system.faction" type="text" value="{{system.faction}}" />
                        </div>
                        <div class="subfaction">
                            <label>{{localize "BIO.SUBFACTION"}}</label>
                            <input name="system.subfaction" type="text" value="{{system.subfaction}}" />
                        </div>
                        <div class="fatigue">
                            <label>{{localize "FATIGUE"}}</label>
                            <input name="system.fatigue.value" type="number" value="{{source.fatigue.value}}" data-dtype="Number" />
                            /
                            <input name="system.fatigue.max" type="number" value="{{system.fatigue.max}}" data-dtype="Number" disabled />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="sheet-tabs tabs flex row" data-group="primary">
            <b class="item" data-action="tab" data-group="primary" data-tab="stats">{{localize "TAB.STATS"}}</b>
            <b class="item" data-action="tab" data-group="primary" data-tab="combat">{{localize "TAB.COMBAT"}}</b>
            <b class="item" data-action="tab" data-group="primary" data-tab="abilities">{{localize "TAB.ABILITIES"}}</b>
            <b class="item" data-action="tab" data-group="primary" data-tab="psychic-powers">{{localize "TAB.PSYCHIC_POWERS"}}</b>
            <b class="item" data-action="tab" data-group="primary" data-tab="gear">{{localize "TAB.GEAR"}}</b>
            <b class="item" data-action="tab" data-group="primary" data-tab="progression">{{localize "TAB.ADVANCES"}}</b>
            <b class="item" data-action="tab" data-group="primary" data-tab="notes">{{localize "TAB.NOTES"}}</b>
        </div>

        <div class="sheet-body">
            <div class="tab" data-group="primary" data-tab="stats">
                {{> systems/dark-heresy/template/sheet/actor/tab/npc-stats.hbs}}
            </div>
            <div class="tab" data-group="primary" data-tab="combat">
                {{> systems/dark-heresy/template/sheet/actor/tab/combat.hbs}}
            </div>
            <div class="tab" data-group="primary" data-tab="abilities">
                {{> systems/dark-heresy/template/sheet/actor/tab/abilities.hbs}}
            </div>
            <div class="tab" data-group="primary" data-tab="effects">
                {{> systems/dark-heresy/template/sheet/item/parts/effect-part.hbs}}
            </div>
            <div class="tab" data-group="primary" data-tab="psychic-powers">
                {{> systems/dark-heresy/template/sheet/actor/tab/psychic-powers.hbs}}
            </div>
            <div class="tab" data-group="primary" data-tab="gear">
                {{> systems/dark-heresy/template/sheet/actor/tab/gear.hbs}}
            </div>
            <div class="tab" data-group="primary" data-tab="progression">
                {{> systems/dark-heresy/template/sheet/actor/tab/progression.hbs}}
            </div>
            <div class="tab" data-group="primary" data-tab="notes">
                {{> systems/dark-heresy/template/sheet/actor/tab/npc-notes.hbs}}
            </div>
        </div>
    </div>
