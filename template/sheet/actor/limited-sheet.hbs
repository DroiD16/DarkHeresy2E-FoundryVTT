  <div class="limited-sheet">
    <div class="header border">
      <div class="flex row">
        <div class="avatar">
          <img class="profile-img" src="{{actor.img}}" alt="{{actor.name}}" data-edit="img" data-action="editImage" title="{{actor.name}}"/>
        </div>
        <div class="flex column grow">
          <div class="name header-row">
            <label>{{localize "BIO.NAME"}}</label>
            <span>{{actor.name}}</span>
          </div>
        </div>
      </div>
    </div>

<!--    <div class="flex wrap">-->
      <div class="flex wrap notes-editor border">
        <h1>{{localize "TITLE.NOTES"}}</h1>
        <div class="notes-editor-content">
          {{#if (eq actor.type "npc")}}
          <prose-mirror name="system.notes" toggled value="{{system.notes}}" {{#unless editable}}disabled{{/unless}}>{{{enrichment.system.notes}}}</prose-mirror>
          {{else}}
          <prose-mirror name="system.bio.notes" toggled value="{{system.bio.notes}}" {{#unless editable}}disabled{{/unless}}>{{{enrichment.system.bio.notes}}}</prose-mirror>
          {{/if}}
        </div>
      </div>
  </div>
