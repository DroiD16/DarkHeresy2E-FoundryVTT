<div class="flex wrap gear">
    <div class="encumbrance border">
        <h1>{{localize "TITLE.ENCUMBRANCE"}}</h1>
        <div class="information">
            <div class="current">
                <label>{{localize "ENCUMBRANCE.CURRENT"}}</label>
                <input type="number" value="{{system.encumbrance.value}}" data-dtype="Number" disabled />
            </div>
            <div class="max">
                <label>{{localize "ENCUMBRANCE.MAX"}}</label>
                <input type="number" value="{{system.encumbrance.max}}" data-dtype="Number" disabled />
            </div>
        </div>
    </div>
    <div class="all-gear border">
        <h1>{{localize "TITLE.EQUIPMENT"}}</h1>
        <div class="item-list gear-weapons-table aligned-table">
            <div class="flex header">
                <b class="name">{{localize "WEAPON.HEADER"}}</b>
                <b class="class">{{localize "WEAPON.CLASS"}}</b>
                <b class="class">{{localize "WEAPON.TYPE"}}</b>
                <b class="damage">{{localize "WEAPON.DAMAGE"}}</b>
                <b class="type">{{localize "WEAPON.DAMAGE_TYPE"}}</b>
                <b class="clip">{{localize "WEAPON.CLIP"}}</b>
                <b class="weight">{{localize "WEAPON.WEIGHT"}}</b>
                <a class="button item-create" title="{{localize 'BUTTON.ADD' type=(localize 'TYPES.Item.weapon')}}" data-type="weapon"><i class="fas fa-plus"></i></a>
            </div>
            <div class="items">
                {{#each items.weapons as |item|}}
                    <div class="gear item draggable" data-item-id="{{item.id}}">
                        <div class="flex row">
                            <div class="flex name item-edit">
                                <div class="image-container">
                                    <div class="image" style="background-image: url('{{item.img}}')"></div>
                                </div>
                                <div>{{item.name}}</div>
                            </div>
                            <div class="class">{{item.WeaponClass}}</div>
                            <div class="class">{{item.WeaponType}}</div>
                            <div class="damage">{{item.damage}}</div>
                            <div class="type">{{item.DamageTypeShort}}</div>
                            <div class="clip">{{item.Clip}}</div>
                            <div class="weight">{{item.weight}}</div>
                            <div class="button">
                                <a class="item-control item-delete" title="{{localize 'BUTTON.DELETE' type=(localize 'TYPES.Item.weapon')}}"><i
                                        class="fas fa-trash"></i></a>
                            </div>
                        </div>
                        {{#each item.system.ammoItems as |ammo|}}
                            <div class="linked-item flex row" data-ammo-id="{{ammo.id}}">
                                <div class="button">
                                    <a class="item-control ammo-unlink" title="{{localize 'AMMUNITION.UNLINK'}}"><i
                                            class="fas fa-chain-broken"></i></a>
                                </div>
                                <div>&#8627 {{ammo.name}}</div>
                            </div>
                        {{/each}}
                    </div>
                {{/each}}
            </div>
        </div>
        <div class="item-list gear-modifications-table aligned-table">
            <div class="flex header">
                <b class="name">{{localize "WEAPON_MODIFICATION.HEADER"}}</b>
                <b class="installed">{{localize "WEAPON_MODIFICATION.INSTALLED"}}</b>
                <b class="upgrade">{{localize "WEAPON_MODIFICATION.UPGRADES"}}</b>
                <b class="weight">{{localize "WEAPON_MODIFICATION.WEIGHT"}}</b>
                <a class="button item-create" title="{{localize 'BUTTON.ADD' type=(localize 'TYPES.Item.weaponmodification')}}" data-type="weaponModification"><i
                        class="fas fa-plus"></i></a>
            </div>
            <div class="items">
                {{#each items.weaponMods as |item|}}
                    <div class="gear item flex row draggable" data-item-id="{{item.id}}">
                        <div class="flex name item-edit">
                            <div class="image-container">
                                <div class="image" style="background-image: url('{{item.img}}')"></div>
                            </div>
                            <div>{{item.name}}</div>
                        </div>
                        <div class="installed"><input type="checkbox" class="item-installed-toggle" {{#if item.system.installed}}checked{{/if}} {{#unless @root.editable}}disabled{{/unless}} title="{{localize "WEAPON_MODIFICATION.INSTALLED"}}" /></div>
                        <div class="upgrade">{{item.upgrades}}</div>
                        <div class="weight">{{item.weight}}</div>
                        <div class="button">
                            <a class="item-control item-delete" title="{{localize 'BUTTON.DELETE' type=(localize 'TYPES.Item.weaponmodification')}}"><i
                                    class="fas fa-trash"></i></a>
                        </div>
                    </div>

                {{/each}}
            </div>
        </div>
        <div class="item-list gear-ammunition-table aligned-table">
            <div class="flex header">
                <b class="name">{{localize "AMMUNITION.HEADER"}}</b>
                <b class="weapon">{{localize "AMMUNITION.WEAPON"}}</b>
                <b class="quantity">{{localize "AMMUNITION.QUANTITY"}}</b>
                <b class="sum-weight">{{localize "AMMUNITION.SUM"}}</b>
                <b class="weight">{{localize "AMMUNITION.WEIGHT"}}</b>
