<div class="dark-heresy-item">
    <div class="header border">
        <div class="flex row">
            <div class="avatar">
                <img class="profile-img" src="{{item.img}}" alt="{{item.name}}" data-edit="img" data-action="editImage" title="{{item.name}}" />
            </div>
            <div class="flex column grow justify-center">
                <div class="name header-row">
                    <label>{{localize "WEAPON.NAME"}}</label>
                    <input name="name" type="text" value="{{item.name}}" />
                </div>
            </div>
        </div>
    </div>

    <div class="sheet-tabs tabs flex row" data-group="primary">
        <b class="item" data-action="tab" data-group="primary" data-tab="data">{{localize "TAB.DATA"}}</b>
        <b class="item" data-action="tab" data-group="primary" data-tab="notes">{{localize "TAB.NOTES"}}</b>
        {{> systems/dark-heresy/template/sheet/item/parts/effect-tab-nav.hbs}}
    </div>

    <div class="sheet-body">
        <div class="tab" data-group="primary" data-tab="data">
            <div class="stats border">
                <h1>{{localize "TITLE.STATS"}}</h1>
                <div class="stats-row">
                    <div class="stat class">
                        <label>{{localize "WEAPON.CLASS"}}</label>
                        <select name="system.class">
                            {{selectOptions (config "weaponClass") selected=system.class localize=true}}
                        </select>
                    </div>
					<div class="stat type">
                        <select name="system.type">
                            {{selectOptions (config "weaponType") selected=system.type localize=true}}
                        </select>
                    </div>
                    <div class="stat range">
                        <label>{{localize "WEAPON.RANGE"}}</label>
                        <input name="system.range" type="number" value="{{system.range}}" data-dtype="Number" />
                    </div>
                    <div class="stat reload">
                        <label>{{localize "WEAPON.RELOAD_FULL"}}</label>
                        <input name="system.reload" type="text" value="{{system.reload}}" />
                    </div>
                    <div class="stat clip">
                        <label>{{localize "WEAPON.CLIP"}}</label>
                        <input style="margin-left: 8px" name="system.clip.value" type="number" value="{{system.clip.value}}" data-dtype="Number" />
                        /
                        <input name="system.clip.max" type="number" value="{{system.clip.max}}" data-dtype="Number" />
                    </div>
                </div>
                <div class="stats-row">
                    <div class="stat damage">
                        <label>{{localize "WEAPON.DAMAGE_FULL"}}</label>
                        <input name="system.damage" type="text" value="{{system.damage}}" />
                        <select name="system.damageType">
                            {{selectOptions (config "damageTypes") selected=system.damageType localize=true}}
                        </select>
                    </div>
                    <div class="stat penetration">
                        <label>{{localize "WEAPON.PENETRATION"}}</label>
                        <input name="system.penetration" type="text" value="{{system.penetration}}" />
                    </div>
                    <div class="stat rate-of-fire">
                        <label>{{localize "WEAPON.RATE_OF_FIRE_FULL"}}</label>
                        <input style="margin-left: 8px" name="system.rateOfFire.single" type="number" value="{{system.rateOfFire.single}}" data-dtype="Number" />
                        /
                        <input name="system.rateOfFire.burst" type="number" value="{{system.rateOfFire.burst}}" data-dtype="Number" />
                        /
                        <input name="system.rateOfFire.full" type="number" value="{{system.rateOfFire.full}}" data-dtype="Number" />
                    </div>
                </div>
                <div class="stats-row">
                    <div class="stat craftsmanship">
                        <label>{{localize "WEAPON.CRAFTSMANSHIP"}}</label>
                        <select name="system.craftsmanship">
                            {{selectOptions (config "craftmanship") selected=system.craftsmanship localize=true}}
                        </select>
                    </div>
                    <div class="stat availability">
                        <label>{{localize "WEAPON.AVAILABILITY"}}</label>
                        <select name="system.availability">
                            {{selectOptions (config "availability") selected=system.availability localize=true}}
                        </select>
                    </div>
                    <div class="stat weight">
                        <label>{{localize "WEAPON.WEIGHT"}}</label>
                        <input name="system.weight" type="number" value="{{system.weight}}" data-dtype="Number" />
                    </div>
                </div>
                <div class="stats-row attack-malfunction-row">
                    <div class="stat ammunition">
                        <label>{{localize "AMMUNITION.HEADER"}}</label>
                        <select class="weapon-ammunition-add" {{#unless hasActor}}disabled{{/unless}} {{#unless editable}}disabled{{/unless}}>
                            <option value="">{{localize "WEAPON.ADD_AMMUNITION"}}</option>
                            {{selectOptions ammunitionOptions valueAttr="id" labelAttr="name"}}
                        </select>
                    </div>
                    <div class="stat malfunction">
                        <label>{{localize "WEAPON.MALFUNCTION"}}</label>
                        <input type="checkbox" name="system.malfunction" data-dtype="Boolean" {{#if system.malfunction}}checked{{/if}} />
                    </div>
                    <div class="stat attack">
                        <label>{{localize "WEAPON.ATTACK"}}</label>
                        <input name="system.attack" type="number" value="{{system.attack}}" data-dtype="Number" />
                    </div>
                </div>
                {{#if system.ammoItems.length}}
                <div class="stats-row linked-ammunition-row">
                    <div class="stat linked-ammunition">
                        <label>{{localize "WEAPON.LINKED_AMMUNITION"}}</label>
                        <div class="linked-ammunition-list">
                            {{#each system.ammoItems as |ammo|}}
                                <span class="linked-ammunition-chip" data-ammo-id="{{ammo.id}}">
                                    <span>{{ammo.name}}</span>
                                    {{#if @root.editable}}
                                        <a class="weapon-ammunition-unlink" data-ammo-id="{{ammo.id}}"
                                           title="{{localize 'AMMUNITION.UNLINK'}}" aria-label="{{localize 'AMMUNITION.UNLINK'}}"><i class="fas fa-chain-broken"></i></a>
                                    {{/if}}
                                </span>
                            {{/each}}
                        </div>
                    </div>
                </div>
                {{/if}}
                <div class="stats-row special-row">
                    <div class="stat special">
                        <label>{{localize "WEAPON.SPECIAL"}}</label>
                        <input name="system.special" type="text" value="{{system.special}}" />
                    </div>
                </div>
                <div class="stats-row special-qualities-row">
                    <div class="stat special-qualities">
                        <label>{{localize "WEAPON.SPECIAL_QUALITIES"}}</label>
                        {{#if editable}}
                            <select class="add-quality-select">
                                <option value="">{{localize "WEAPON.ADD_QUALITY"}}</option>
                                {{#each qualityOptions}}<option value="{{key}}">{{label}}</option>{{/each}}
                            </select>
                        {{/if}}
                    </div>
                </div>
                {{#if qualityChips}}
                <div class="stats-row quality-chips-row">
                    <div class="quality-chips border">
                        {{#each qualityChips}}
                            <span class="quality-chip" data-key="{{key}}">
                                <span class="quality-chip-label" {{#if desc}}data-tooltip="{{desc}}" data-tooltip-class="dark-heresy-tooltip"{{/if}}>{{label}}</span>
                                {{#if hasValue}}
                                    <input class="quality-value-input" type="number" data-key="{{key}}"
                                           value="{{value}}" min="0" step="1" data-dtype="Number" {{#unless @root.editable}}disabled{{/unless}} />
                                {{/if}}
                                {{#if @root.editable}}
                                    <a class="remove-quality" data-key="{{key}}" title="{{localize 'WEAPON.REMOVE_QUALITY'}}">
                                        <i class="fas fa-trash"></i></a>
                                {{/if}}
                            </span>
                        {{/each}}
                    </div>
                </div>
                {{/if}}
            </div>
        </div>
        <div class="tab" data-group="primary" data-tab="notes">
            <div class="notes-editor border">
                <h1>{{localize "TITLE.NOTES"}}</h1>
                <div class="notes-editor-body">
                    <prose-mirror name="system.description" toggled value="{{system.description}}" {{#unless editable}}disabled{{/unless}}>{{{enrichment.system.description}}}</prose-mirror>
                </div>
            </div>
        </div>
        {{> systems/dark-heresy/template/sheet/item/parts/effect-tab.hbs}}
    </div>
</div>
